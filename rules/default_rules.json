{
  "meta": {
    "name": "n8n-workflow-audit-default-rules",
    "version": "1.5.0"
  },
  "settings": {
    "expected_notion_update_event": "pagedUpdatedInDatabase",
    "placeholder_markers": [
      "PLACEHOLDER",
      "TBD",
      "TODO",
      "MAIN_WORKFLOW_ID",
      "<WORKFLOW_ID>"
    ],
    "status_field_keywords": [
      "status",
      "文案狀態",
      "公司資料查詢"
    ],
    "status_node_name_keywords": [
      "status",
      "狀態",
      "重查",
      "潤稿"
    ],
    "forbidden_pattern_strings": [
      "Object.prototype.hasOwnProperty.call(",
      ".__proto__",
      ".prototype."
    ],
    "notion_simple_required_operations": [
      "get",
      "getAll"
    ],
    "notion_filter_required_operations": [
      "getAll"
    ],
    "magic_fallback_patterns": [
      "set(estKey, 99)",
      "safeCount=99",
      "safeCount = 99"
    ],
    "gemini_deprecated_model_names": [
      "gemini-2.0-flash",
      "models/gemini-2.0-flash",
      "gemini-2.0-flash-exp",
      "gemini-2.0-pro-exp"
    ],
    "gemini_deprecated_model_pattern": "gemini-2\\.0",
    "tax_id_field_keywords": [
      "taxId",
      "統編",
      "統一編號",
      "tax_id",
      "businessNumber"
    ]
  },
  "rules": [
    {
      "id": "N8N-001",
      "title": "Notion status parsing must support flattened payload",
      "severity": "FAIL",
      "enabled": true
    },
    {
      "id": "N8N-002",
      "title": "Status-driven Notion trigger must use update event",
      "severity": "FAIL",
      "enabled": true
    },
    {
      "id": "N8N-003",
      "title": "Execute Workflow must bind a concrete workflow id",
      "severity": "FAIL",
      "enabled": true
    },
    {
      "id": "N8N-004",
      "title": "Expression/code must avoid sandbox-forbidden prototype access",
      "severity": "FAIL",
      "enabled": true
    },
    {
      "id": "N8N-005",
      "title": "Audit output contract and exit code",
      "severity": "PASS",
      "enabled": true
    },
    {
      "id": "N8N-006",
      "title": "Notion get/getAll must set simple=false for properties access",
      "severity": "FAIL",
      "enabled": true
    },
    {
      "id": "N8N-007",
      "title": "Notion getAll must use a precise filter (no implicit full scan)",
      "severity": "FAIL",
      "enabled": true
    },
    {
      "id": "N8N-008",
      "title": "Notion filterJson should avoid nested AND/OR compound patterns",
      "severity": "WARN",
      "enabled": true
    },
    {
      "id": "N8N-009",
      "title": "Code nodes must not use magic high-count fallback on query error",
      "severity": "FAIL",
      "enabled": true
    },
    {
      "id": "N8N-010",
      "title": "Notion node __rl Resource Locator must not be deployed via API",
      "severity": "FAIL",
      "enabled": true
    },
    {
      "id": "N8N-011",
      "title": "Google Gemini model name must not have redundant models/ prefix",
      "severity": "FAIL",
      "enabled": true
    },
    {
      "id": "N8N-012",
      "title": "Google Gemini model name must not be a deprecated or unavailable alias",
      "severity": "WARN",
      "enabled": true
    },
    {
      "id": "N8N-013",
      "title": "Expression fields must not use IIFE with $json access",
      "severity": "FAIL",
      "enabled": true
    },
    {
      "id": "N8N-014",
      "title": "Code nodes must not use setTimeout for timing delays",
      "severity": "FAIL",
      "enabled": true
    },
    {
      "id": "N8N-015",
      "title": "Data-loading getAll/read nodes must not use onError: continueRegularOutput",
      "severity": "WARN",
      "enabled": true
    },
    {
      "id": "N8N-016",
      "title": "Code node must not use sandbox-forbidden modules (fs, crypto, AbortController)",
      "severity": "FAIL",
      "enabled": true
    },
    {
      "id": "N8N-017",
      "title": "OData $filter comparison value must be wrapped in single quotes",
      "severity": "WARN",
      "enabled": true
    },
    {
      "id": "N8N-018",
      "title": "IF node unary operator must set singleValue: true",
      "severity": "FAIL",
      "enabled": true
    },
    {
      "id": "N8N-019",
      "title": "Code node must not use Array.isArray($json) (always false after HTTP Request)",
      "severity": "WARN",
      "enabled": true
    },
    {
      "id": "N8N-020",
      "title": "Code node must not use .all()[0] hard-coded index inside loop workflows",
      "severity": "WARN",
      "enabled": true
    },
    {
      "id": "N8N-021",
      "title": "Sheets-sourced tax-ID-like fields must be normalized with padStart",
      "severity": "WARN",
      "enabled": true
    },
    {
      "id": "N8N-022",
      "title": "HTTP Request must not use overly long inline JSON body expressions",
      "severity": "WARN",
      "enabled": true
    },
    {
      "id": "N8N-023",
      "title": "Code node in runOnceForEachItem mode must not return a non-empty array literal",
      "severity": "FAIL",
      "enabled": true
    },
    {
      "id": "N8N-024",
      "title": "Notion update workflows must include an archived/in_trash page guard",
      "severity": "WARN",
      "enabled": true
    }
  ]
}
